# .env.local — copy and fill in values from your Supabase project dashboard
# Never commit this file

# ── Supabase ──────────────────────────────────────────────────────────────────
# Project Settings > API > Project URL
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Project Settings > API > anon (public) key
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Project Settings > API > service_role (secret) key
# Used only in createAdminClient() — never exposed to browser
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Optional: Sentry error tracking ──────────────────────────────────────────
# SENTRY_DSN=https://...@sentry.io/...
# NEXT_PUBLIC_SENTRY_DSN=https://...@sentry.io/...

# ── Optional: Analytics ───────────────────────────────────────────────────────
# NEXT_PUBLIC_POSTHOG_KEY=phc_...
# NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ── AI: DeepSeek (history generator) ─────────────────────────────────────────
# Get free key at https://platform.deepseek.com
# Used only server-side in the history generator AI mode
DEEPSEEK_API_KEY=sk-...
